<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================ -->
    <!-- Dark Theme — AKILIMO brand on dark surfaces                 -->
    <!-- Primary:   #9DD768 (lightened AKILIMO green for dark bg)   -->
    <!-- Secondary: #BFCA6A (warm lime)                             -->
    <!-- Tertiary:  #FFB3B4 (AKILIMO red softened for dark)         -->
    <!-- ============================================================ -->
    <style name="Base.Theme.NewAkilimo" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Primary (bright green readable on dark bg) -->
        <item name="colorPrimary">@color/color_dark_primary</item>
        <item name="colorOnPrimary">@color/color_dark_on_primary</item>
        <item name="colorPrimaryContainer">@color/color_dark_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/color_dark_on_primary_container</item>

        <!-- Secondary (warm lime on dark) -->
        <item name="colorSecondary">@color/color_dark_secondary</item>
        <item name="colorOnSecondary">@color/color_dark_on_secondary</item>
        <item name="colorSecondaryContainer">@color/color_dark_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/color_dark_on_secondary_container</item>

        <!-- Tertiary (AKILIMO red softened) -->
        <item name="colorTertiary">@color/color_dark_tertiary</item>
        <item name="colorOnTertiary">@color/color_dark_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/color_dark_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/color_dark_on_tertiary_container</item>

        <!-- Surface and background (deep warm-dark green) -->
        <item name="android:colorBackground">@color/color_dark_background</item>
        <item name="colorOnBackground">@color/color_dark_on_background</item>
        <item name="colorSurface">@color/color_dark_surface</item>
        <item name="colorOnSurface">@color/color_dark_on_surface</item>
        <item name="colorSurfaceVariant">@color/color_dark_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/color_dark_on_surface_variant</item>

        <!-- Error colors -->
        <item name="colorError">@color/color_dark_error</item>
        <item name="colorOnError">@color/color_dark_on_error</item>
        <item name="colorErrorContainer">@color/color_dark_error_container</item>
        <item name="colorOnErrorContainer">@color/color_dark_on_error_container</item>

        <!-- Outline and borders -->
        <item name="colorOutline">@color/color_dark_outline</item>
        <item name="colorOutlineVariant">@color/color_dark_outline_variant</item>

        <!-- Ripple / control highlight -->
        <item name="android:colorControlHighlight">@color/color_dark_ripple</item>

        <!-- Typography color roles -->
        <item name="android:textColorPrimary">@color/color_dark_text_primary</item>
        <item name="android:textColorSecondary">@color/color_dark_text_secondary</item>
        <item name="android:textColorTertiary">@color/color_dark_text_tertiary</item>
        <item name="android:textColorHint">@color/color_dark_text_disabled</item>

        <!-- System bars — match dark background -->
        <item name="android:statusBarColor">@color/color_dark_background</item>
        <item name="android:navigationBarColor">@color/color_dark_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/color_dark_background</item>

        <!-- Material3 elevation overlays -->
        <item name="elevationOverlayEnabled">true</item>

    </style>

    <!-- Main dark theme -->
    <style name="Theme.NewAkilimo" parent="Base.Theme.NewAkilimo" />

    <!-- Dark splash screen -->
    <style name="Theme.NewAkilimo.Splash" parent="Theme.NewAkilimo">
        <item name="android:windowBackground">@color/color_dark_background</item>
        <item name="android:statusBarColor">@color/color_dark_background</item>
        <item name="android:navigationBarColor">@color/color_dark_background</item>
    </style>

    <!-- Dark edge-to-edge variant -->
    <style name="Theme.NewAkilimo.EdgeToEdge" parent="Theme.NewAkilimo">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">true</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">true</item>
    </style>

</resources>
