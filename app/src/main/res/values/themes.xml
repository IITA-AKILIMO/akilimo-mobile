<resources>
    <!--
        Minimal XML theme — Compose owns all theming via AkilimoTheme.
        This only exists, so the Activity window doesn't flash white before
        the first Compose frame, and to suppress the default ActionBar.
    -->
    <style name="Theme.NewAkilimo" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">@color/color_background</item>
    </style>
</resources>
