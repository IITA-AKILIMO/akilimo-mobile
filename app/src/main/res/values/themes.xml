<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================================ -->
    <!-- Base Akilimo theme — Material3 DayNight, AKILIMO brand      -->
    <!-- Primary:   AKILIMO Green  #3D7600                           -->
    <!-- Secondary: IITA Lime-Earth #586200                          -->
    <!-- Tertiary:  AKILIMO Red    #B5162A                           -->
    <!-- Font:      Google Sans                                       -->
    <!-- ============================================================ -->
    <style name="Base.Theme.NewAkilimo" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Typography - Google Sans throughout -->
        <item name="fontFamily">@font/google_sans</item>
        <item name="android:fontFamily">@font/google_sans</item>

        <!-- Primary brand colors (AKILIMO Green) -->
        <item name="colorPrimary">@color/color_primary</item>
        <item name="colorOnPrimary">@color/color_on_primary</item>
        <item name="colorPrimaryContainer">@color/color_primary_light</item>
        <item name="colorOnPrimaryContainer">@color/color_on_primary_container</item>

        <!-- Secondary brand colors (IITA Lime-Earth) -->
        <item name="colorSecondary">@color/color_secondary</item>
        <item name="colorOnSecondary">@color/color_on_secondary</item>
        <item name="colorSecondaryContainer">@color/color_secondary_light</item>
        <item name="colorOnSecondaryContainer">@color/color_on_secondary_container</item>

        <!-- Tertiary (AKILIMO Logo Red) -->
        <item name="colorTertiary">@color/color_tertiary</item>
        <item name="colorOnTertiary">@color/color_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/color_tertiary_light</item>
        <item name="colorOnTertiaryContainer">@color/color_on_tertiary_container</item>

        <!-- Surface and background (tonal warm-green surfaces) -->
        <item name="android:colorBackground">@color/color_background</item>
        <item name="colorOnBackground">@color/color_on_background</item>
        <item name="colorSurface">@color/color_surface</item>
        <item name="colorOnSurface">@color/color_on_surface</item>
        <item name="colorSurfaceVariant">@color/color_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/color_on_surface_variant</item>

        <!-- Error colors -->
        <item name="colorError">@color/color_error</item>
        <item name="colorOnError">@color/color_on_error</item>
        <item name="colorErrorContainer">@color/color_error_container</item>
        <item name="colorOnErrorContainer">@color/color_on_error_container</item>

        <!-- Outline and borders -->
        <item name="colorOutline">@color/color_outline</item>
        <item name="colorOutlineVariant">@color/color_outline_variant</item>

        <!-- Ripple / control highlight -->
        <item name="android:colorControlHighlight">@color/color_ripple</item>

        <!-- Typography color roles -->
        <item name="android:textColorPrimary">@color/color_text_primary</item>
        <item name="android:textColorSecondary">@color/color_text_secondary</item>
        <item name="android:textColorTertiary">@color/color_text_tertiary</item>
        <item name="android:textColorHint">@color/color_text_disabled</item>

        <!-- System bars — dark status bar (green), light nav bar -->
        <item name="android:statusBarColor">@color/color_primary</item>
        <item name="android:navigationBarColor">@color/color_surface</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>

        <!-- Window -->
        <item name="android:windowBackground">@color/color_background</item>

        <!-- Material3 elevation overlays -->
        <item name="elevationOverlayEnabled">true</item>

        <!-- Divider -->
        <item name="materialDividerStyle">@style/Widget.Material3.MaterialDivider</item>

        <!-- ── Widget Styles ──────────────────────────────────────── -->

        <!-- Filled button: pill shape, 48dp min height -->
        <item name="materialButtonStyle">@style/Widget.Akilimo.Button</item>

        <!-- Outlined button -->
        <item name="materialButtonOutlinedStyle">@style/Widget.Akilimo.Button.Outlined</item>

        <!-- Text button -->
        <item name="borderlessButtonStyle">@style/Widget.Akilimo.Button.Text</item>

        <!-- Cards -->
        <item name="materialCardViewStyle">@style/Widget.Akilimo.CardView</item>

        <!-- Text input (OutlinedBox with rounded corners) -->
        <item name="textInputStyle">@style/Widget.Akilimo.TextInputLayout</item>

        <!-- Chips -->
        <item name="chipStyle">@style/Widget.Akilimo.Chip</item>

        <!-- ── Typography Scale ───────────────────────────────────── -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.Akilimo.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.Akilimo.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.Akilimo.DisplaySmall</item>

        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Akilimo.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Akilimo.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Akilimo.HeadlineSmall</item>

        <item name="textAppearanceTitleLarge">@style/TextAppearance.Akilimo.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Akilimo.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Akilimo.TitleSmall</item>

        <item name="textAppearanceBodyLarge">@style/TextAppearance.Akilimo.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Akilimo.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Akilimo.BodySmall</item>

        <item name="textAppearanceLabelLarge">@style/TextAppearance.Akilimo.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Akilimo.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Akilimo.LabelSmall</item>
    </style>

    <!-- ── Main app theme ────────────────────────────────────────── -->
    <style name="Theme.NewAkilimo" parent="Base.Theme.NewAkilimo" />

    <!-- Splash screen: full-bleed primary green -->
    <style name="Theme.NewAkilimo.Splash" parent="Theme.NewAkilimo">
        <item name="android:windowBackground">@color/color_primary</item>
        <item name="android:statusBarColor">@color/color_primary</item>
        <item name="android:navigationBarColor">@color/color_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
    </style>

    <!-- Edge-to-edge: transparent system bars -->
    <style name="Theme.NewAkilimo.EdgeToEdge" parent="Theme.NewAkilimo">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">true</item>
        <item name="android:enforceNavigationBarContrast" tools:targetApi="q">false</item>
        <item name="android:enforceStatusBarContrast" tools:targetApi="q">false</item>
    </style>

    <!-- ============================================================ -->
    <!-- Shape Appearances                                            -->
    <!-- ============================================================ -->

    <!-- Pill shape for buttons — very modern M3 look -->
    <style name="ShapeAppearance.Akilimo.Button" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">50%</item>
    </style>

    <!-- Rounded cards — 12dp corners -->
    <style name="ShapeAppearance.Akilimo.Card" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

    <!-- Extra rounded for bottom sheets / dialogs -->
    <style name="ShapeAppearance.Akilimo.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- ============================================================ -->
    <!-- Widget Styles                                                -->
    <!-- ============================================================ -->

    <!-- Filled Button -->
    <style name="Widget.Akilimo.Button" parent="Widget.Material3.Button">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Akilimo.Button</item>
        <item name="android:letterSpacing">0.01</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Outlined Button -->
    <style name="Widget.Akilimo.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Akilimo.Button</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Text Button -->
    <style name="Widget.Akilimo.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:minHeight">48dp</item>
        <item name="shapeAppearance">@style/ShapeAppearance.Akilimo.Button</item>
    </style>

    <!-- Elevated Card -->
    <style name="Widget.Akilimo.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="shapeAppearance">@style/ShapeAppearance.Akilimo.Card</item>
        <item name="cardElevation">2dp</item>
        <item name="checkedIconTint">@color/color_primary</item>
    </style>

    <!-- Outlined Text Input -->
    <style name="Widget.Akilimo.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxStrokeColor">@color/color_outline</item>
    </style>

    <!-- Chip -->
    <style name="Widget.Akilimo.Chip" parent="Widget.Material3.Chip.Filter">
        <item name="chipMinHeight">36dp</item>
        <item name="chipCornerRadius">18dp</item>
    </style>

    <!-- ============================================================ -->
    <!-- Toolbar Text Appearances                                     -->
    <!-- ============================================================ -->

    <style name="TextAppearance.Akilimo.Toolbar.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/color_on_primary</item>
        <item name="android:fontFamily">@font/google_sans_medium</item>
        <item name="android:letterSpacing">0</item>
    </style>

    <style name="TextAppearance.Akilimo.Toolbar.Subtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/color_on_primary</item>
        <item name="android:fontFamily">@font/google_sans</item>
        <item name="android:alpha">0.87</item>
    </style>

    <!-- Secondary Toolbar -->
    <style name="Widget.Akilimo.Toolbar.Secondary" parent="Widget.Material3.Toolbar">
        <item name="android:background">@color/color_secondary</item>
        <item name="titleTextColor">@color/color_on_secondary</item>
        <item name="subtitleTextColor">@color/color_on_secondary</item>
        <item name="navigationIconTint">@color/color_on_secondary</item>
    </style>

    <!-- Collapsing Toolbar -->
    <style name="Widget.Akilimo.CollapsingToolbar" parent="Widget.Material3.CollapsingToolbar.Large">
        <item name="contentScrim">@color/color_primary</item>
        <item name="statusBarScrim">@color/color_primary_variant</item>
        <item name="collapsedTitleTextColor">@color/color_on_primary</item>
        <item name="expandedTitleTextColor">@color/color_on_primary</item>
        <item name="expandedTitleTextAppearance">@style/TextAppearance.Akilimo.Toolbar.Title.Expanded</item>
    </style>

    <style name="TextAppearance.Akilimo.Toolbar.Title.Expanded" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/color_on_primary</item>
        <item name="android:fontFamily">@font/google_sans_medium</item>
    </style>

    <!-- Toolbar Menu -->
    <style name="Widget.Akilimo.Toolbar.Menu" parent="Widget.Material3.Toolbar">
        <item name="android:textColorPrimary">@color/color_on_primary</item>
        <item name="android:textColorSecondary">@color/color_on_primary</item>
        <item name="actionMenuTextColor">@color/color_on_primary</item>
        <item name="iconTint">@color/color_on_primary</item>
    </style>

</resources>
