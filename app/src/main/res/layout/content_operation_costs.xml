<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/appbar_padding_top"
    tools:showIn="@layout/fragment_operation_cost_dialog">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@{operationCost.email}" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_first_manual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="First ploughing operation, manual by hand hoe">

        <EditText
            android:id="@+id/txtManualFirstOp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="19000" />

    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_first_plough_tractor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="First ploughing operation, by tractor+plough">

        <EditText
            android:id="@+id/txtTractorPloughFirstOp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="10000" />
    </com.google.android.material.textfield.TextInputLayout>


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_second_manual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Second ploughing operation, manual by hand hoe">

        <EditText
            android:id="@+id/txtManualSecondOp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="15000" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_second_plough_tractor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Second ploughing operation, by tractor+plough">

        <EditText
            android:id="@+id/txtTractorPloughSecondOp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="8000" />
    </com.google.android.material.textfield.TextInputLayout>


    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_harrow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Harrowing, by tractor+harrow">

        <EditText
            android:id="@+id/txtHarrowOp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="8000" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_ridging_manual"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ridging, manual by hand hoe">

        <EditText
            android:id="@+id/txtRidgingManualOp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="7500" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/input_layout_ridging_tractor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Ridging, by tractor+ridger">

        <EditText
            android:id="@+id/txtRidgingTractorOp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="7500" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@{operationCost.email}" />
</LinearLayout>
