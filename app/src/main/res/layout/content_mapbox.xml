<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:mapbox="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    app:layout_behavior="@string/appbar_scrolling_view_behavior"
    tools:context=".views.activities.MapBoxActivity"
    tools:showIn="@layout/activity_map_box">

    <com.mapbox.mapboxsdk.maps.MapView
        android:id="@+id/mapView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        mapbox:mapbox_cameraTargetLat="-1.2240615"
        mapbox:mapbox_cameraTargetLng="36.9003409"
        mapbox:mapbox_cameraZoom="5"
        mapbox:mapbox_uiRotateGestures="false" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/select_location_button"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_gravity="bottom"
        android:text="@string/lbl_select_location" />
</RelativeLayout>